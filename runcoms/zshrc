  source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh"
fi

# Customize to your needs...
bindkey -v
bindkey "^R" history-incremental-pattern-search-backward
bindkey "^L" autosuggest-accept

eval "$(starship init zsh)"

export STARSHIP_CONFIG="$HOME/.zprezto/starship.toml"
export VISUAL=mvim
export EDITOR=mvim
export PATH=.:$HOME/bin:$HOME/.npm-global/bin:~/.composer/vendor/bin:/Users/ericpridham/bin:~/.composer/vendor/bin:$PATH:$HOME/.cargo/bin:$HOME/.local/bin

source secrets

alias s="vendor/bin/sail"

alias z="fasd_cd -d"
alias ls="ls -F --color"

export NVM_DIR="$HOME/.nvm"
