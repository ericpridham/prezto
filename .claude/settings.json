{
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:docs.anthropic.com)",
      "Bash(ls:*)",
      "Bash(php artisan test:*)",
      "Bash(echo:*)",
      "Bash(./vendor/bin/phpunit:*)",
      "Bash(php artisan tinker:*)",
      "Bash(php -l:*)",
      "Bash(php -r:*)",
      "Bash(git add:*)",
      "Bash(dip pest:*)",
      "Bash(git -C /Users/ericpridham/athena/subscription-service status)",
      "Bash(git -C /Users/ericpridham/athena/subscription-service diff --staged)",
      "Bash(git -C /Users/ericpridham/athena/subscription-service log --oneline -5)",
      "Bash(git commit:*)",
      "Bash(dip composer require:*)",
      "Bash(php:*)",
      "Bash(git checkout:*)",
      "Bash(python3:*)",
      "Bash(dip php:*)",
      "Bash(dip bash -c \"vendor/bin/pest tests/Unit/Library/StripeGatewayTest.php --filter=''attaches payment method and sets as default in updateBillingInfo'' -vvv\")",
      "Bash(claude-code:*)",
      "Bash(grep:*)",
      "Bash(pkill:*)",
      "Bash(dip artisan test:*)",
      "Bash(dip composer show:*)",
      "Bash(find:*)",
      "Bash(claude --agent code-developer --message \"Fix the oracle tagging in /Users/ericpridham/athena/subscription-service/app/Http/Controllers/StripeWebhookController.php.\n\nThe problem: Lines 37-39 try to tag all webhook payload fields, but Stripe webhooks contain nested arrays/objects that can''t be tagged as scalar values.\n\nChange lines 37-39 from:\n\\\\`\\\\`\\\\`php\nforeach \\($payload as $field => $value\\) {\n    oracle\\(\\)->tag\\(\"\"webhook.{$field}\"\", $value\\);\n}\n\\\\`\\\\`\\\\`\n\nto:\n\\\\`\\\\`\\\\`php\nforeach \\($payload as $field => $value\\) {\n    if \\(is_scalar\\($value\\)\\) {\n        oracle\\(\\)->tag\\(\"\"webhook.{$field}\"\", $value\\);\n    }\n}\n\\\\`\\\\`\\\\`\n\nThis is the only change needed. Don''t modify anything else.\")",
      "Bash(claude task:*)",
      "Bash(claude:*)",
      "Bash(git status:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(dip artisan tinker:*)",
      "Bash(git diff:*)",
      "WebSearch",
      "WebFetch(domain:docs.stripe.com)",
      "Bash(git log:*)",
      "Bash(gh pr view:*)",
      "Bash(gh api:*)",
      "Bash(dip composer check-platform-reqs:*)",
      "Bash(dip artisan migrate:fresh:*)",
      "Bash(dip composer update:*)",
      "Bash(gem pristine:*)",
      "Bash(brew reinstall:*)",
      "Bash(brew info:*)",
      "Bash(brew list:*)",
      "Bash(/opt/homebrew/bin/dip composer update:*)",
      "Bash(brew link:*)",
      "Bash(git rm:*)",
      "Bash(git -C /Users/ericpridham/athena/subscription-service diff)",
      "Bash(git -C /Users/ericpridham/athena/subscription-service add app/Http/Controllers/RecurlyController.php app/Library/Decorators/InstrumentedRecurlyClient.php composer.json composer.lock config/flow-opentracing-zipkin.php config/flow.php phpunit.xml config/athena-oracle.php)",
      "Bash(git -C:*)",
      "Bash(docker ps:*)",
      "Bash(docker compose run:*)",
      "Bash(docker network ls:*)",
      "Bash(docker exec:*)",
      "Bash(docker compose restart:*)",
      "Bash(docker compose down:*)",
      "Bash(docker volume ls:*)",
      "Bash(dip down:*)",
      "Bash(dip up:*)",
      "WebFetch(domain:api.github.com)",
      "Bash(gh pr:*)",
      "Bash(dip exec:*)",
      "Bash(dip composer:*)",
      "Bash(dip artisan:*)",
      "Bash(dip pint:*)",
      "Bash(dip ls:*)"
    ],
    "defaultMode": "plan"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh 'Waiting for permission approval' &"
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh 'Has a question for you' &"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh 'Task complete, awaiting input' &"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "atlassian@claude-plugins-official": true,
    "skillsky-api-builder@skillsky-claude-marketplace-preview": true,
    "daily-briefing@skillsky-claude-marketplace": true,
    "claude-usage@skillsky-claude-marketplace": true,
    "cowsay@skillsky-claude-marketplace": true
  },
  "extraKnownMarketplaces": {
    "skillsky-claude-marketplace": {
      "source": {
        "source": "github",
        "repo": "continued-llc/skillsky-claude-marketplace",
        "ref": "main"
      }
    },
    "skillsky-claude-marketplace-preview": {
      "source": {
        "source": "github",
        "repo": "continued-llc/skillsky-claude-marketplace",
        "ref": "preview"
      },
      "installLocation": "/Users/ericpridham/.claude/plugins/marketplaces/skillsky-claude-marketplace-preview"
    }
  },
  "sandbox": {
    "autoAllowBashIfSandboxed": true
  },
  "skipDangerousModePermissionPrompt": true
}
